@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Học Phí - EduConnect</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="app-layout">
        <!-- Navigation Sidebar Placeholder -->
        <div id="sidebar-container"></div>

        <div class="main-content">
            <div class="dashboard-container">
                <header class="main-header">
                    <div class="header-title">
                        <h1 data-i18n="tuition">Quản lý Học phí</h1>
                        <p>&#8594; Tra cứu công nợ, hóa đơn điện tử và thanh toán học phí nhanh chóng.</p>
                    </div>
                    <div class="header-actions">
                        <div class="child-selector" id="childSelector" data-aos="fade-down" data-aos-delay="100"></div>
                    </div>
                </header>


                <div class="content-grid">
                    <div class="left-column">
                        <div class="card" data-aos="fade-up">
                            <div class="card-header">
                                <h2>Lịch sử Giao dịch & Hóa đơn</h2>
                            </div>
                            <div class="table-responsive">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th data-i18n="invoiceId">Mã HD</th>
                                            <th data-i18n="period">Kỳ học</th>
                                            <th data-i18n="amount">Số tiền</th>
                                            <th data-i18n="date">Ngày đóng</th>
                                            <th data-i18n="status">Trạng thái</th>
                                            <th data-i18n="download">Tải xuống</th>
                                        </tr>

                                    </thead>
                                    <tbody id="tuitionTableBody">
                                        <!-- Rendered via JS -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Phương thức thanh toán (QR Code) -->
                <div class="modal-overlay" id="paymentModal">
                    <div class="modal-content"
                        style="background:var(--card-bg); padding:24px; border-radius:var(--border-radius-lg); text-align:center; width: 350px;">
                        <div class="modal-header" style="justify-content:center; margin-bottom: 20px;">
                            <h3 style="margin: 0;">Mã VietQR Thanh Toán</h3>
                        </div>
                        <div id="qrcode" style="display:flex; justify-content:center; margin-bottom: 20px;"></div>
                        <div id="paymentDesc" style="margin-bottom: 20px; font-size: 14px; color: var(--text-muted)">
                        </div>
                        <button class="btn btn-primary" onclick="closePaymentModal()" style="width:100%">Đã thanh toán /
                            Đóng</button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>

    
    <!-- App Entry Point -->
    <script src="/js/main.js" type="module"></script>


</body>

</html>
